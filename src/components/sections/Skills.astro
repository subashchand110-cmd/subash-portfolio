---
import { skillCategories } from "../../data/skills";

import {
  Cloud,
  Server,
  Network,
  Shield,
  Wrench
} from "@lucide/astro";

const icons = {
  cloud: Cloud,
  server: Server,
  network: Network,
  shield: Shield,
  tool: Wrench
};
---

<section id="skills" class="skills">

  <div class="container">

    <div class="section-header">

      <span class="section-tag">

        <Server size={18} />

        Technical Skills

      </span>

      <h2>Technologies & Platforms</h2>

      <p>
        Technical skills developed through university, certifications,
        home labs and continuous hands-on learning.
      </p>

    </div>

    <div class="skills-grid">

      {
        skillCategories.map((category) => {

          const Icon = icons[category.icon];

          return (

            <article class="card skill-card">

              <h3 class="card-title">

                <Icon size={20} />

                <span>{category.title}</span>

              </h3>

              <div class="skill-list">

                {
                  category.skills.map((skill) => (

                    <span class="pill">

                      {skill}

                    </span>

                  ))
                }

              </div>

            </article>

          );

        })
      }

    </div>

  </div>

</section>