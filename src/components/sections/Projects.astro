---
import { projects } from "../../data/projects";

import {
  FolderGit2,
  GitBranch,
  ExternalLink,
  Calendar,
  Star,
  CheckCircle2,
  Laptop,
  Cloud,
  Server
} from "@lucide/astro";

const typeIcons = {
  Web: Laptop,
  Cloud: Cloud,
  Infrastructure: Server
};
---

<section id="projects" class="projects">

  <div class="container">

    <div class="section-header">

      <span class="section-tag">

        <FolderGit2 size={18} />

        Projects

      </span>

      <h2>Featured Projects</h2>

      <p>
        Practical projects and home labs demonstrating my growing skills in
        cloud, infrastructure and modern web technologies.
      </p>

    </div>

    <div class="projects-grid">

      {
        projects.map((project) => {

          const Icon = typeIcons[project.type];

          return (

            <article class="card project-card">

              {project.featured && (

                <span class="featured-badge">

                  <Star size={14} />

                  Featured Project

                </span>

              )}

              <div class="project-header">

                <div>

                  <h3 class="card-title">

                    {Icon && <Icon size={22} />}

                    <span>{project.title}</span>

                  </h3>

                </div>

              </div>

              <div class="project-meta">

                <span class="project-type">

                  {project.type}

                </span>

                <span class={`status ${project.status.toLowerCase().replace(/\s+/g, "-")}`}>

                  {project.status}

                </span>

                <span>

                  <Calendar size={15} />

                  {project.year}

                </span>

              </div>

              <p class="project-description">

                {project.description}

              </p>

              <h4>Highlights</h4>

              <ul class="highlight-list">

                {
                  project.highlights.map((item) => (

                    <li>

                      <CheckCircle2 size={16} />

                      <span>{item}</span>

                    </li>

                  ))
                }

              </ul>

              <div class="tech-stack">

                {
                  project.technologies.map((tech) => (

                    <span class="pill">

                      {tech}

                    </span>

                  ))
                }

              </div>

              <div class="project-links">

                {

                  project.github && (

                    <a
                      href={project.github}
                      target="_blank"
                      class="btn btn-secondary"
                    >

                      <GitBranch size={18} />

                      GitHub

                    </a>

                  )

                }

                {

                  project.demo && project.demo !== "#" && (

                    <a
                      href={project.demo}
                      target="_blank"
                      class="btn btn-primary"
                    >

                      <ExternalLink size={18} />

                      Live Demo

                    </a>

                  )

                }

              </div>

            </article>

          );

        })
      }

    </div>

  </div>

</section>