---
import { experience } from "../../data/experience";

import {
  BriefcaseBusiness,
  Building2,
  CalendarDays,
  CheckCircle2
} from "@lucide/astro";
---

<section id="experience" class="experience">

  <div class="container">

    <div class="section-header">

      <span class="section-tag">

        <BriefcaseBusiness size={18} />

        Experience

      </span>

      <h2>Professional Experience</h2>

      <p>
        Professional experience that has strengthened my leadership,
        communication, customer service and problem-solving abilities—skills
        that transfer directly into IT Support and Infrastructure roles.
      </p>

    </div>

    <div class="experience-grid">

      {
        experience.map((job) => (

          <article class="card experience-card">

            <span class="experience-badge">

              Current Position

            </span>

            <h3 class="card-title">

              <BriefcaseBusiness size={20} />

              <span>{job.role}</span>

            </h3>

            <div class="experience-meta">

              <span>

                <Building2 size={16} />

                {job.company}

              </span>

              <span>

                <CalendarDays size={16} />

                {job.period}

              </span>

            </div>

            <p class="experience-description">

              {job.description}

            </p>

            <h4>

              Key Responsibilities

            </h4>

            <ul class="achievement-list">

              {
                job.achievements.map((achievement) => (

                  <li>

                    <CheckCircle2 size={16} />

                    <span>{achievement}</span>

                  </li>

                ))
              }

            </ul>

            <h4>

              Transferable Skills

            </h4>

            <div class="skill-tags">

              {
                job.skills.map((skill) => (

                  <span class="pill">

                    {skill}

                  </span>

                ))
              }

            </div>

          </article>

        ))
      }

    </div>

  </div>

</section>